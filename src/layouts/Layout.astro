---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl } from '../i18n/translations';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  article?: { date?: string; category?: string; };
}

const { title, description = 'MDK.GURU - Один человек. Пять ИИ-агентов. Бесконечные возможности.', ogImage, article } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const canonicalUrl = new URL(Astro.url.pathname, 'https://mdk.guru').href;

const websiteSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "MDK.GURU",
  "url": "https://mdk.guru",
  "description": "Один человек. Пять ИИ-агентов. Бесконечные возможности.",
  "author": { "@type": "Person", "name": "Ilya Chernyak" },
  "inLanguage": ["ru", "en", "es"],
});

const articleSchema = article ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": ogImage ? `https://mdk.guru${ogImage}` : "https://mdk.guru/og-image.png",
  "datePublished": article.date,
  "author": { "@type": "Person", "name": "Ilya Chernyak" },
  "publisher": { "@type": "Organization", "name": "MDK.GURU", "logo": { "@type": "ImageObject", "url": "https://mdk.guru/favicon.svg" } },
  "mainEntityOfPage": canonicalUrl,
}) : null;
---

<!doctype html>
<html lang={lang} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage || 'https://mdk.guru/og-image.png'} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="MDK.GURU" />
    <meta property="og:locale" content={lang === 'ru' ? 'ru_RU' : lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage ? `https://mdk.guru${ogImage}` : 'https://mdk.guru/og-image.png'} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="ru" href={`https://mdk.guru/ru${Astro.url.pathname.replace(/^\/(ru|en|es)/, '')}`} />
    <link rel="alternate" hreflang="en" href={`https://mdk.guru/en${Astro.url.pathname.replace(/^\/(ru|en|es)/, '')}`} />
    <link rel="alternate" hreflang="es" href={`https://mdk.guru/es${Astro.url.pathname.replace(/^\/(ru|en|es)/, '')}`} />
    <link rel="alternate" hreflang="x-default" href={`https://mdk.guru/ru${Astro.url.pathname.replace(/^\/(ru|en|es)/, '')}`} />
    <script type="application/ld+json" set:html={websiteSchema} />
    {articleSchema && <script type="application/ld+json" set:html={articleSchema} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Michroma&display=swap" as="style" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Michroma&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Michroma&display=swap" rel="stylesheet" /></noscript>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | MDK.GURU</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Global SVG gradient for icons -->
    <svg width="0" height="0" class="absolute">
      <defs>
        <linearGradient id="solanaGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#9945FF" />
          <stop offset="100%" stop-color="#14F195" />
        </linearGradient>
      </defs>
    </svg>
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
