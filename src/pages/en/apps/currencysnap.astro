---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="CurrencySnap - Camera Currency Converter" description="Point camera at a price tag, see it in your currency. 30 currencies, offline, free.">
  <div class="pt-24 min-h-screen">
    <div class="max-w-3xl mx-auto px-4 py-16">
      <a href="/en/apps" class="text-sm text-text-muted hover:text-accent-purple transition-colors">&larr; All apps</a>

      <div class="mt-8 mb-12">
        <h1 class="text-4xl font-bold mb-3"><span class="gradient-text">CurrencySnap</span></h1>
        <p class="text-xl text-text-muted">Camera Currency Converter</p>
      </div>

      <div class="card-hover p-8 rounded-xl border border-border bg-bg-card mb-8">
        <p class="text-text-muted leading-relaxed mb-6">
          Point your camera at any price tag — see it in your home currency instantly. CurrencySnap turns your iPhone camera into a live currency converter. No typing. No searching. One glance.
        </p>

        <h2 class="text-lg font-bold text-white mb-4">Features</h2>
        <ul class="space-y-3 text-text-muted">
          <li class="flex items-start gap-3">
            <span class="text-accent-green mt-1">&#10003;</span>
            <span><strong class="text-white">Camera Conversion</strong> — point at price tags, menus, receipts, see result instantly</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-green mt-1">&#10003;</span>
            <span><strong class="text-white">30 Currencies</strong> — USD, EUR, GBP, TRY, THB, JPY and 24 more popular destinations</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-green mt-1">&#10003;</span>
            <span><strong class="text-white">Favorites</strong> — pin your most-used currency pairs for one-tap access</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-green mt-1">&#10003;</span>
            <span><strong class="text-white">Works Offline</strong> — exchange rates cached locally, convert without Wi-Fi</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-green mt-1">&#10003;</span>
            <span><strong class="text-white">Free Forever</strong> — no ads, no subscription, no account required</span>
          </li>
        </ul>
      </div>

      <div class="card-hover p-8 rounded-xl border border-border bg-bg-card mb-8">
        <h2 class="text-lg font-bold text-white mb-4">Coming to App Store</h2>
        <p class="text-text-muted">CurrencySnap is preparing for release. Free for iOS.</p>
      </div>

      <div class="card-hover p-8 rounded-xl border border-border bg-bg-card mb-8">
        <h2 class="text-lg font-bold text-white mb-4">Privacy</h2>
        <p class="text-text-muted mb-3">Camera is used only for on-device OCR price recognition. Images are not stored or transmitted.</p>
        <a href="/apps/currencysnap/privacy" class="text-sm text-accent-purple hover:underline">Privacy Policy &rarr;</a>
      </div>

      <div class="text-sm text-text-muted">
        <p>Questions or feedback: <a href="mailto:support@mdk.guru" class="text-accent-purple hover:underline">support@mdk.guru</a></p>
      </div>
    </div>
  </div>
</Layout>
