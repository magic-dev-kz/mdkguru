---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="MyWins - Success Diary" description="Success diary in 30 seconds. Voice input, insights, calendar heatmap, Face ID. Free forever.">
  <div class="pt-24 min-h-screen">
    <div class="max-w-3xl mx-auto px-4 py-16">
      <a href="/en/apps" class="text-sm text-text-muted hover:text-accent-purple transition-colors">&larr; All apps</a>

      <div class="flex items-center gap-6 mt-8 mb-12">
        <img src="/apps/winlog-icon.png" alt="MyWins icon" width="128" height="128" class="rounded-[28px] shadow-lg" />
        <div>
          <h1 class="text-4xl font-bold mb-3"><span class="gradient-text">MyWins</span></h1>
          <p class="text-xl text-text-muted">Success Diary</p>
        </div>
      </div>

      <div class="card-hover p-8 rounded-xl border border-border bg-bg-card mb-8">
        <p class="text-text-muted leading-relaxed mb-6">
          Every evening, you achieve more than you think. But by tomorrow — you forget. MyWins captures your daily wins in 30 seconds. Inspired by the success diary from Bodo Schafer's "Money."
        </p>

        <h2 class="text-lg font-bold text-white mb-4">Features</h2>
        <ul class="space-y-3 text-text-muted">
          <li class="flex items-start gap-3">
            <span class="text-accent-green mt-1">&#10003;</span>
            <span><strong class="text-white">Voice Input</strong> — tap the mic, speak your win. 30 seconds, no typing</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-green mt-1">&#10003;</span>
            <span><strong class="text-white">Insights Dashboard</strong> — 6 metrics: best streak, top category, weekly growth</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-green mt-1">&#10003;</span>
            <span><strong class="text-white">Calendar Heatmap</strong> — your year in color. GitHub-style for real life</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-green mt-1">&#10003;</span>
            <span><strong class="text-white">Face ID Lock</strong> — your diary is protected. Nobody reads it without your face</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-green mt-1">&#10003;</span>
            <span><strong class="text-white">Free Forever</strong> — no ads, no subscription, no account required</span>
          </li>
        </ul>
      </div>

      <div class="card-hover p-8 rounded-xl border border-border bg-bg-card mb-8">
        <h2 class="text-lg font-bold text-white mb-4">Coming to App Store</h2>
        <p class="text-text-muted">MyWins is preparing for release. Free for iOS.</p>
      </div>

      <div class="card-hover p-8 rounded-xl border border-border bg-bg-card mb-8">
        <h2 class="text-lg font-bold text-white mb-4">Privacy</h2>
        <p class="text-text-muted mb-3">All data stored on your device only. No cloud, no analytics, no tracking.</p>
        <a href="/apps/winlog/privacy" class="text-sm text-accent-purple hover:underline">Privacy Policy &rarr;</a>
      </div>

      <div class="text-sm text-text-muted">
        <p>Questions or feedback: <a href="mailto:magic4e@gmail.com" class="text-accent-purple hover:underline">magic4e@gmail.com</a></p>
      </div>
    </div>
  </div>
</Layout>
