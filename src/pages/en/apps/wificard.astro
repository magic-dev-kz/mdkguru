---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="WifiCard - WiFi QR Cards" description="Beautiful WiFi QR cards. Guests scan and connect. 6 templates, print, offline. Free.">
  <div class="pt-24 min-h-screen">
    <div class="max-w-3xl mx-auto px-4 py-16">
      <a href="/en/apps" class="text-sm text-text-muted hover:text-accent-purple transition-colors">&larr; All apps</a>

      <div class="flex items-center gap-6 mt-8 mb-12">
        <img src="/apps/wificard-icon.png" alt="WifiCard icon" width="128" height="128" class="rounded-[28px] shadow-lg" />
        <div>
          <h1 class="text-4xl font-bold mb-3"><span class="gradient-text">WifiCard</span></h1>
          <p class="text-xl text-text-muted">WiFi QR Cards</p>
        </div>
      </div>

      <!-- Screenshots -->
      <div class="mb-12 overflow-x-auto">
        <div class="flex gap-4 pb-4" style="min-width: max-content;">
          <img src="/apps/wificard/screenshots/en/screenshot_1.png" alt="WiFi card preview" class="h-[500px] rounded-2xl shadow-lg" loading="lazy" />
          <img src="/apps/wificard/screenshots/en/screenshot_2.png" alt="QR code" class="h-[500px] rounded-2xl shadow-lg" loading="lazy" />
          <img src="/apps/wificard/screenshots/en/screenshot_3.png" alt="Template selection" class="h-[500px] rounded-2xl shadow-lg" loading="lazy" />
          <img src="/apps/wificard/screenshots/en/screenshot_4.png" alt="Saved networks" class="h-[500px] rounded-2xl shadow-lg" loading="lazy" />
          <img src="/apps/wificard/screenshots/en/screenshot_5.png" alt="Share card" class="h-[500px] rounded-2xl shadow-lg" loading="lazy" />
          <img src="/apps/wificard/screenshots/en/screenshot_6.png" alt="Dark mode" class="h-[500px] rounded-2xl shadow-lg" loading="lazy" />
          <img src="/apps/wificard/screenshots/en/screenshot_7.png" alt="Settings" class="h-[500px] rounded-2xl shadow-lg" loading="lazy" />
        </div>
      </div>

      <div class="card-hover p-8 rounded-xl border border-border bg-bg-card mb-8">
        <p class="text-text-muted leading-relaxed mb-6">
          Enter your WiFi name and password — get a beautiful card with a QR code. Guests scan it and connect automatically. No more spelling out passwords letter by letter. Done in 5 seconds.
        </p>

        <h2 class="text-lg font-bold text-white mb-4">Features</h2>
        <ul class="space-y-3 text-text-muted mb-6">
          <li class="flex items-start gap-3">
            <span class="text-accent-green mt-1">&#10003;</span>
            <span><strong class="text-white">Print-Ready PDF</strong> — print 6 cards on one A4 page with cut guides. Perfect for cafés, hotels, Airbnb. AirPrint support</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-green mt-1">&#10003;</span>
            <span><strong class="text-white">6 Designer Templates</strong> — Minimal, Warm, Hotel, Airbnb, Tech, Kids. Pick the one that matches your space</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-green mt-1">&#10003;</span>
            <span><strong class="text-white">QR Code</strong> — guests point camera, connect without typing password. No mistakes, no "was that a capital S?"</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-green mt-1">&#10003;</span>
            <span><strong class="text-white">Print and Share</strong> — AirPrint, AirDrop, Messages, Mail. Print it, share it, or save as an image</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-green mt-1">&#10003;</span>
            <span><strong class="text-white">100% Offline</strong> — your password never leaves your device. No internet connection needed. No tracking. No analytics. Nothing</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-green mt-1">&#10003;</span>
            <span><strong class="text-white">Free Forever</strong> — no ads, no subscription, no account required</span>
          </li>
        </ul>

        <h2 class="text-lg font-bold text-white mb-4">Perfect For</h2>
        <p class="text-text-muted leading-relaxed">
          Airbnb & vacation rental hosts. Hotels, hostels, B&Bs. Cafes, restaurants, coworking spaces. Or simply your home — for guests and family.
        </p>
      </div>

      <div class="card-hover p-8 rounded-xl border border-border bg-bg-card mb-8">
        <h2 class="text-lg font-bold text-white mb-4">Coming to App Store</h2>
        <p class="text-text-muted">WifiCard is preparing for release. Free for iOS.</p>
      </div>

      <div class="card-hover p-8 rounded-xl border border-border bg-bg-card mb-8">
        <h2 class="text-lg font-bold text-white mb-4">Privacy</h2>
        <p class="text-text-muted mb-3">Your WiFi password never leaves your device. No network calls, no server, no analytics.</p>
        <a href="/apps/wificard/privacy" class="text-sm text-accent-purple hover:underline">Privacy Policy &rarr;</a>
      </div>

      <div class="text-sm text-text-muted">
        <p>Questions or feedback: <a href="mailto:magic4e@gmail.com" class="text-accent-purple hover:underline">magic4e@gmail.com</a></p>
      </div>
    </div>
  </div>
</Layout>
