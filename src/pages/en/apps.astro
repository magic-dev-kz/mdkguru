---
import Layout from '../../layouts/Layout.astro';

const apps = [
  { iconKey: 'snobsnab', icon: '🛒', title: 'SnobSnab', desc: 'Auto-generated content site for construction materials. Gemini research → Claude text → Imagen covers.', status: 'live', url: 'https://www.snobsnab.ru', stack: 'Astro + Vercel + AI Pipeline' },
  { iconKey: 'mdkguru', icon: '🌐', title: 'MDK.GURU', desc: 'This site. One-person studio + AI. Blog, apps, skills. Three languages.', status: 'live', url: 'https://mdk.guru', stack: 'Astro + Tailwind + Decap CMS' },
  { iconKey: 'kazakvpn', icon: '🔐', title: 'KazakVPN', desc: 'iOS VPN client on WireGuard. Simple UI, fast connection.', status: 'development', stack: 'SwiftUI + WireGuardKit' },
];
---

<Layout title="Apps" description="Projects by MDK.GURU studio.">
  <div class="pt-24 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 py-16">
      <h1 class="text-4xl font-bold mb-2"><span class="gradient-text">Apps</span></h1>
      <p class="text-text-muted mb-12">Built by one person + AI team.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {apps.map(app => (
          <div class="card-hover p-6 rounded-xl border border-border bg-bg-card">
            <span class="text-3xl">{app.icon}</span>
            <h3 class="text-lg font-bold text-white mt-3 mb-2">{app.title}</h3>
            <p class="text-sm text-text-muted mb-3">{app.desc}</p>
            <p class="text-xs text-text-muted">{app.stack}</p>
            {app.url && <a href={app.url} target="_blank" class="inline-block mt-3 text-sm text-accent-purple hover:underline">Open →</a>}
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>
