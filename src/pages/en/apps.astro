interface AppItem {
  iconKey: string;
  title: string;
  desc: string;
  status: string;
  url?: string;
  slug?: string;
  stack: string;
}

const webApps: AppItem[] = [
  { iconKey: 'snobsnab', title: 'SnobSnab', desc: 'Auto-generated content site for construction materials. Gemini research, Claude text, Imagen covers.', status: 'live', url: 'https://www.snobsnab.ru', stack: 'Astro + Vercel + AI Pipeline' },
  { iconKey: 'mdkguru', title: 'MDK.GURU', desc: 'This site. One-person studio + AI. Blog, apps, skills. Three languages.', status: 'live', url: 'https://mdk.guru', stack: 'Astro + Tailwind + Decap CMS' },
  { iconKey: 'kazakvpn', title: 'KazakVPN', desc: 'iOS VPN client on WireGuard. Simple UI, fast connection.', status: 'development', stack: 'SwiftUI + WireGuardKit' },
  { iconKey: 'qr', title: 'QR Payment', desc: 'Photo of invoice to OCR to QR code for bank app payment.', status: 'development', stack: 'Python + qrcode + OCR' },
];

const iosApps: AppItem[] = [
  { iconKey: 'roomcalc', title: 'RoomCalc', desc: '8 construction calculators + shopping list. Tile, paint, wallpaper, concrete. Free forever, no ads, offline.', status: 'beta', slug: 'roomcalc', stack: 'SwiftUI' },
  { iconKey: 'drift', title: 'NudgeBit', desc: 'Gentle habit tracker. Momentum instead of streaks. Rest days built in. One habit at a time.', status: 'live', slug: 'drift', stack: 'SwiftUI + iCloud' },
  { iconKey: 'pollenpal', title: 'PollenPal: Allergy Forecast', desc: 'Real help for allergy sufferers. Personal Safety Score by YOUR allergens. Pollen + air quality. Best hour to go outside.', status: 'live', slug: 'pollenpal', stack: 'SwiftUI + Open-Meteo API' },
  { iconKey: 'winlog', title: 'WinBoard', desc: 'Success diary in 30 seconds. Voice input, insights, calendar heatmap, Face ID. Bodo Schafer method.', status: 'beta', slug: 'winlog', stack: 'SwiftUI + Apple Speech' },
  { iconKey: 'wificard', title: 'WifiCard', desc: 'Beautiful WiFi QR cards. Guests scan and connect. 6 templates, print, offline.', status: 'beta', slug: 'wificard', stack: 'SwiftUI + CoreImage' },
  { iconKey: 'huecraft', title: 'HueForge', desc: 'One HEX, full design system. 40+ tokens, light + dark mode, WCAG auto-fix. CSS, Swift, Tailwind, JSON.', status: 'beta', slug: 'huecraft', stack: 'SwiftUI + OKLCH' },
  { iconKey: 'currencysnap', title: 'PriceFlip', desc: 'Point camera at a price tag, see it in your currency. 150+ currencies, offline, built for travelers.', status: 'beta', slug: 'currencysnap', stack: 'SwiftUI + VisionKit' },
  { iconKey: 'roast', title: 'Roast My Listing', desc: 'AI listing critic. Paste text, get a score, flaw breakdown, and a ready rewrite. On-device AI.', status: 'beta', slug: 'roast-my-listing', stack: 'SwiftUI + Apple Intelligence' },
  { iconKey: 'decode', title: 'Decode My Boss', desc: 'Corporate speak decoder. Paste a message from your boss, get the real meaning and toxicity score.', status: 'beta', slug: 'decode-my-boss', stack: 'SwiftUI + Apple Intelligence' },
  { iconKey: 'labelwise', title: 'ScanLabel', desc: 'Food label scanner. 236 E-numbers decoded, dietary alerts, ingredient safety ratings. On-device AI.', status: 'beta', slug: 'labelwise', stack: 'SwiftUI + VisionKit + Foundation Models' },
  { iconKey: 'ghostkitchen', title: 'FridgeMenu', desc: 'AI cooking assistant. 40 built-in recipes, voice-guided cooking mode, pantry management. On-device AI.', status: 'beta', slug: 'ghostkitchen', stack: 'SwiftUI + Foundation Models + Speech' },
];

const statusLabels: Record<string, { text: string; color: string }> = {
  live: { text: 'Live', color: 'bg-accent-green/20 text-accent-green' },
  beta: { text: 'Coming Soon', color: 'bg-accent-blue/20 text-accent-blue' },
  development: { text: 'In development', color: 'bg-accent-purple/20 text-accent-purple' },
};
---

<Layout title="Apps" description="iOS apps and web projects by MDK.GURU studio. Free utilities with no ads.">
  <div class="pt-24 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 py-16">
      <h1 class="text-4xl font-bold mb-2"><span class="gradient-text">Apps</span></h1>
      <p class="text-text-muted mb-12">Built by one person + AI team.</p>

      <h2 class="text-2xl font-bold text-white mb-6">iOS</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">
        {iosApps.map(app => (
          <a href={`/en/apps/${app.slug}`} class="card-hover p-6 rounded-xl border border-border bg-bg-card block transition-transform hover:scale-[1.02]">
            <div class="flex items-start justify-between mb-3">
              <div class="w-10 h-10" set:html={appIcons[app.iconKey]} />
              <span class={`text-xs px-2 py-1 rounded-full ${statusLabels[app.status].color}`}>
                {statusLabels[app.status].text}
              </span>
            </div>
            <h3 class="text-lg font-bold text-white mb-2">{app.title}</h3>
            <p class="text-sm text-text-muted mb-3">{app.desc}</p>
            <p class="text-xs text-text-muted">{app.stack}</p>
          </a>
        ))}
      </div>

      <h2 class="text-2xl font-bold text-white mb-6">Web Projects</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {webApps.map(app => (
          <div class="card-hover p-6 rounded-xl border border-border bg-bg-card">
            <div class="flex items-start justify-between mb-3">
              <div class="w-10 h-10" set:html={appIcons[app.iconKey]} />
              <span class={`text-xs px-2 py-1 rounded-full ${statusLabels[app.status].color}`}>
                {statusLabels[app.status].text}
              </span>
            </div>
            <h3 class="text-lg font-bold text-white mb-2">{app.title}</h3>
            <p class="text-sm text-text-muted mb-3">{app.desc}</p>
            <p class="text-xs text-text-muted">{app.stack}</p>
            {app.url && <a href={app.url} target="_blank" class="inline-block mt-3 text-sm text-accent-purple hover:underline">Open &rarr;</a>}
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>
