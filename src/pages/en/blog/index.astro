---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts.filter(p => {
  const ident = p.id || p.slug || '';
  return ident.startsWith('en/') || ident.startsWith('en\\');
}).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

function getSlug(post: any) {
  const ident = post.id || post.slug || '';
  return ident.replace(/^en[/\\]/, '').replace(/\.md$/, '');
}
---

<Layout title="Blog" description="Practice, cases, lessons. No fluff.">
  <div class="pt-24 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 py-16">
      <h1 class="text-4xl font-bold mb-2"><span class="gradient-text">Blog</span></h1>
      <p class="text-text-muted mb-12">Practice, cases, lessons. No fluff.</p>
      <div class="space-y-6">
        {posts.map(post => (
          <a href={`/en/blog/${getSlug(post)}`} class="block card-hover p-6 rounded-xl border border-border bg-bg-card group">
            <h2 class="text-xl font-semibold text-white group-hover:text-accent-green transition-colors mb-2">{post.data.title}</h2>
            <p class="text-text-muted text-sm">{post.data.description}</p>
          </a>
        ))}
        {posts.length === 0 && (
          <div class="text-center py-20 text-text-muted"><p>Articles coming soon <svg viewBox="0 0 24 24" fill="none" stroke="url(#solanaGrad)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-[1.2em] h-[1.2em] inline-block align-text-bottom mx-[0.1em]"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"></path><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"></path></svg></p></div>
        )}
      </div>
    </div>
  </div>
</Layout>
