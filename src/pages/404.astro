---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404">
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center">
      <h1 class="text-8xl font-bold gradient-text mb-4">404</h1>
      <p class="text-xl text-text-secondary mb-8">Страница не найдена</p>
      <a href="/ru" class="px-6 py-3 rounded-lg bg-gradient-to-r from-accent-purple to-accent-green text-white font-semibold hover:opacity-90 transition-opacity">
        На главную
      </a>
    </div>
  </div>
</Layout>
