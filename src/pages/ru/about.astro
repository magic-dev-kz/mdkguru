---
import Layout from '../../layouts/Layout.astro';

const agents = [
  {
    name: "Мо", role: "COO", emoji: "⚙️", color: "#3C64DC",
    avatar: "/agents/avatar_mo.png",
    desc: "Операционный директор. Координирует задачи, готовит аналитику и отчёты, следит за дедлайнами. Основной интерфейс между Ильёй и остальными агентами. Держит всё под контролем и не даёт хаосу победить."
  },
  {
    name: "Изя", role: "SMM", emoji: "📣", color: "#DC32B4",
    avatar: "/agents/avatar_izya.png",
    desc: "SMM-менеджер. Создаёт контент для Instagram, Telegram и ВК — посты, Stories, Reels. Автоматизирует публикацию, следит за вовлечённостью, адаптирует тон под каждую площадку. Знает, когда аудитория онлайн."
  },
  {
    name: "Молот", role: "Scout", emoji: "🔨", color: "#B42828",
    avatar: "/agents/avatar_molot.png",
    desc: "Разведчик. Мониторит конкурентов, собирает тренды, находит материал для контента. Работает по расписанию — каждое утро свежая разведка. Если на рынке что-то изменилось, Молот узнает первым."
  },
  {
    name: "Лео", role: "Design", emoji: "📐", color: "#FFD700",
    avatar: "/agents/avatar_leo.png",
    desc: "Визуал и дизайнер. Маскоты, баннеры, инфографика, 3D-модели. Генеративный дизайн через Gemini, DALL-E, Imagen. Минималист: форма следует смыслу, без декора ради декора."
  },
  {
    name: "Хаус", role: "SRE", emoji: "🩺", color: "#28B450",
    avatar: "/agents/avatar_house.png",
    desc: "Реаниматолог системы. Мониторинг инфраструктуры, диагностика, восстановление. Если сервер упал, крон сломался или сайт лёг — Хаус чинит. Проактивно проверяет здоровье всех сервисов."
  },
  {
    name: "Стив", role: "Product", emoji: "🧭", color: "#E68C1E",
    avatar: "/agents/avatar_steve.png",
    desc: "Продуктовый стратег и ментор. Задаёт правильные вопросы, помогает расставить приоритеты, ревьюит решения. Стив не пишет код — он думает о том, что и зачем мы делаем."
  },
  {
    name: "Макс", role: "Infra", emoji: "⚡", color: "#00DC32",
    avatar: "/agents/avatar_max.png",
    desc: "Инфраструктура и код. Серверы, деплой, автоматизация, assembly-проверки 3D-моделей. Серый кардинал команды — работает тихо, но без него ничего не взлетит."
  },
];
---

<Layout title="О студии" description="MDK.GURU — студия одного человека и семи ИИ-агентов. Илья Черняк, Кемерово.">
  <div class="pt-24 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 py-16">

      <h1 class="text-4xl font-bold mb-4">
        <span class="gradient-text">О студии</span>
      </h1>
      <p class="text-text-muted mb-12 text-lg">Один человек. Семь агентов. Без офиса.</p>

      <div class="space-y-8 text-text-secondary leading-relaxed">

        <div>
          <h2 class="text-xl font-bold text-white mb-3">Кто я</h2>
          <p>Илья Черняк, предприниматель из Кемерово. Три бизнеса: электроника, вейпшопы, аренда оборудования. Двое детей, яхтинг, падел-теннис и постоянное желание автоматизировать всё вокруг.</p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-white mb-3">Что такое MDK.GURU</h2>
          <p>Это не агентство и не студия разработки. Это эксперимент: может ли один человек с командой ИИ-агентов делать то, для чего обычно нужен штат?</p>
          <p class="mt-3">Контент-конвейер, аналитика продаж, мониторинг конкурентов, дизайн — всё это делают мои 7 агентов на базе OpenClaw. 24/7. Без зарплат. Без выходных.</p>
        </div>

        <!-- Team -->
        <div>
          <h2 class="text-xl font-bold text-white mb-6">Команда</h2>
          <div class="space-y-4">
            {agents.map((a) => (
              <div class="p-5 rounded-xl border border-border bg-bg-card flex items-start gap-4 group hover:border-opacity-50 transition-all relative overflow-hidden">
                <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-xl"
                     style={`background: radial-gradient(ellipse at left center, ${a.color}15, transparent 60%);`}></div>
                <div class="relative z-10 flex-shrink-0">
                  <img src={a.avatar} alt={a.name} class="w-20 h-20 rounded-full object-cover ring-2 ring-border group-hover:ring-opacity-60 transition-all" style={`--tw-ring-color: ${a.color}44`} loading="lazy" />
                </div>
                <div class="relative z-10 flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1">
                    <span class="text-lg font-bold text-white">{a.name}</span>
                    <span class="text-xs font-mono px-2 py-0.5 rounded bg-white/5" style={`color: ${a.color}`}>{a.role}</span>
                  </div>
                  <p class="text-sm text-text-muted leading-relaxed">{a.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div>
          <h2 class="text-xl font-bold text-white mb-3">Зачем этот сайт</h2>
          <p>Делюсь практикой. Кейсы, грабли, инструменты. Всё, что узнаю — выкладываю здесь. Без воды, без курсов за сотни тысяч.</p>
          <p class="mt-3">Если ты предприниматель и хочешь понять, как ИИ-агенты могут работать в реальном бизнесе — ты по адресу.</p>
        </div>

        <div class="mt-12 p-6 rounded-xl border border-accent-purple/20 bg-accent-purple/5 text-center">
          <p class="text-white font-semibold mb-2">Следи за экспериментом</p>
          <p class="text-text-muted text-sm mb-4">Канал в Telegram — кейсы, обновления, закулисье</p>
          <a href="https://t.me/mdkguru" target="_blank" class="inline-flex items-center gap-2 px-6 py-2 rounded-lg bg-accent-purple text-white text-sm hover:opacity-90 transition-opacity">
            @mdkguru в Telegram →
          </a>
        </div>

      </div>
    </div>
  </div>
</Layout>
