---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Dashboard" description="Витрина ИИ-студии. 7 агентов, 3 бизнеса, 26 автозадач — в реальном времени.">
  <div class="pt-24 min-h-screen">
    <div class="max-w-5xl mx-auto px-4 py-16">

      <div class="flex items-center justify-between mb-10">
        <div>
          <h1 class="text-4xl sm:text-5xl font-bold"><span class="gradient-text">Dashboard</span></h1>
          <p class="text-text-muted mt-2">Что происходит в студии прямо сейчас</p>
        </div>
        <div class="flex items-center gap-3">
          <div id="system-dot" class="w-3 h-3 rounded-full bg-accent-green animate-pulse"></div>
          <span id="system-status" class="text-sm font-semibold text-white">Загрузка...</span>
        </div>
      </div>

      <div id="highlights-grid" class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-12"></div>

      <h2 class="text-2xl font-bold text-white mb-6">Команда</h2>
      <div id="agents-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 mb-12"></div>

      <h2 class="text-2xl font-bold text-white mb-6">🏅 Медали</h2>
      <div id="medals-catalog" class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6"></div>
      <div id="medals-log" class="mb-12"></div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="p-6 rounded-xl border border-border bg-bg-card">
          <h3 class="text-lg font-semibold text-white mb-4 flex items-center gap-2"><img src="/icons/automation.svg" alt="Автоматизация" class="w-6 h-6 inline-block" /> Автоматизация</h3>
          <div class="space-y-3">
            <div class="flex items-center justify-between"><span class="text-text-muted text-sm">Кронов всего</span><span id="crons-total" class="text-white font-mono font-bold">-</span></div>
            <div class="flex items-center justify-between"><span class="text-text-muted text-sm">Активных</span><span id="crons-active" class="text-accent-green font-mono font-bold">-</span></div>
            <div class="flex items-center justify-between"><span class="text-text-muted text-sm">Ошибки (24ч)</span><span id="crons-errors" class="font-mono font-bold">-</span></div>
          </div>
        </div>
        <div class="p-6 rounded-xl border border-border bg-bg-card">
          <h3 class="text-lg font-semibold text-white mb-4 flex items-center gap-2"><img src="/icons/system.svg" alt="Система" class="w-6 h-6 inline-block" /> Система</h3>
          <div class="space-y-3">
            <div class="flex items-center justify-between"><span class="text-text-muted text-sm">Uptime</span><span id="uptime" class="text-accent-green font-mono font-bold">-</span></div>
            <div class="flex items-center justify-between"><span class="text-text-muted text-sm">Память агентов</span><span id="mem-entries" class="text-white font-mono font-bold">-</span></div>
            <div class="flex items-center justify-between"><span class="text-text-muted text-sm">Диск</span><span id="disk-usage" class="text-white font-mono font-bold">-</span></div>
          </div>
        </div>
      </div>

      <div class="flex items-center justify-between text-xs text-text-muted mt-8">
        <span id="last-update"></span>
        <span>Данные обновляются раз в день</span>
      </div>
    </div>
  </div>
</Layout>

<script>
async function loadDashboard() {
  try {
    const res = await fetch('/dashboard-data.json');
    const data = await res.json();

    const el = document.getElementById('last-update') as HTMLElement;
    if (el) el.textContent = `Обновлено: ${new Date(data.updatedAt).toLocaleString('ru-RU')}`;

    const dot = document.getElementById('system-dot') as HTMLElement;
    const status = document.getElementById('system-status') as HTMLElement;
    if (status) status.textContent = data.system?.status || 'Система работает';
    if (dot && data.system?.healthy === false) dot.className = 'w-3 h-3 rounded-full bg-red-400';

    const hGrid = document.getElementById('highlights-grid') as HTMLElement;
    if (hGrid && data.highlights) {
      hGrid.innerHTML = data.highlights.map((h: any) => {
        const isSvg = h.icon && h.icon.endsWith('.svg');
        const iconHtml = isSvg
          ? `<img src="${h.icon}" alt="${h.label}" class="w-8 h-8 mx-auto" loading="lazy" />`
          : `<span class="text-2xl">${h.icon}</span>`;
        return `
        <div class="p-5 rounded-xl border border-border bg-bg-card text-center group hover:border-accent-purple/30 transition-colors">
          <div class="mb-2">${iconHtml}</div>
          <div class="text-3xl font-bold gradient-text mb-1">${h.value}</div>
          <div class="text-sm text-white font-medium">${h.label}</div>
          <div class="text-xs text-text-muted mt-1">${h.sub}</div>
        </div>`;
      }).join('');
    }

    const grid = document.getElementById('agents-grid') as HTMLElement;
    if (grid && data.agents) {
      const medalCatalog = data.medals?.catalog || [];
      grid.innerHTML = data.agents.map((a: any) => {
        const agentMedals = (a.medals || []).map((m: any) => {
          const cat = medalCatalog.find((c: any) => c.id === m.id);
          if (!cat) return '';
          return `<img src="${cat.icon}" alt="${cat.name}" title="${cat.name} (${m.date})" class="w-6 h-6 rounded-full" loading="lazy" />`;
        }).join('');
        return `
        <div class="p-4 rounded-xl border border-border bg-bg-card group hover:border-opacity-50 transition-all relative overflow-hidden">
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-xl"
               style="background: radial-gradient(ellipse at center, ${a.color}22, transparent 70%);"></div>
          <div class="relative z-10 flex items-center gap-3">
            <div class="relative">
              <img src="${a.avatar}" alt="${a.name}" class="w-12 h-12 rounded-full object-cover ring-2 ring-border" loading="lazy" />
              <div class="absolute -bottom-0.5 -right-0.5 w-3 h-3 rounded-full border-2 border-bg-card ${a.online ? 'bg-green-400' : 'bg-gray-500'}"></div>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <span class="font-semibold text-white">${a.name}</span>
                <span class="text-xs font-mono px-1.5 py-0.5 rounded bg-white/5" style="color: ${a.color}">${a.role}</span>
              </div>
              <p class="text-xs text-text-muted mt-0.5 truncate">${a.lastActivity || ''}</p>
              ${agentMedals ? `<div class="flex gap-1 mt-1.5">${agentMedals}</div>` : ''}
            </div>
          </div>
        </div>`;
      }).join('');
    }

    const medalsCat = document.getElementById('medals-catalog') as HTMLElement;
    if (medalsCat && data.medals?.catalog) {
      medalsCat.innerHTML = data.medals.catalog.map((m: any) => `
        <div class="p-3 rounded-xl border border-border bg-bg-card flex items-center gap-3 group hover:border-opacity-50 transition-all">
          <img src="${m.icon}" alt="${m.name}" class="w-10 h-10 rounded-full" loading="lazy" />
          <div class="text-sm font-semibold text-white">${m.name}</div>
        </div>
      `).join('');
    }

    const medalsLog = document.getElementById('medals-log') as HTMLElement;
    if (medalsLog && data.medals?.log?.length) {
      medalsLog.innerHTML = `
        <div class="p-4 rounded-xl border border-border bg-bg-card">
          <h3 class="text-sm font-semibold text-white mb-3">Последние награждения</h3>
          ${data.medals.log.map((l: any) => {
            const cat = data.medals.catalog.find((c: any) => c.id === l.medal);
            return `<div class="flex items-center gap-3 py-2">
              <img src="${cat?.icon || ''}" alt="" class="w-6 h-6 rounded-full" loading="lazy" />
              <span class="text-sm text-white font-medium">${l.agent}</span>
              <span class="text-xs text-text-muted">—</span>
              <span class="text-xs" style="color: ${cat?.color || '#fff'}">${cat?.name || l.medal}</span>
              <span class="text-xs text-text-muted ml-auto">${l.date}</span>
            </div>`;
          }).join('')}
        </div>`;
    }

    const ct = document.getElementById('crons-total') as HTMLElement;
    const ca = document.getElementById('crons-active') as HTMLElement;
    const ce = document.getElementById('crons-errors') as HTMLElement;
    if (ct) ct.textContent = data.crons?.total ?? '-';
    if (ca) ca.textContent = data.crons?.active ?? '-';
    if (ce) { const e = data.crons?.errors24h ?? 0; ce.textContent = e.toString(); ce.className = `font-mono font-bold ${e === 0 ? 'text-accent-green' : 'text-red-400'}`; }

    const up = document.getElementById('uptime') as HTMLElement;
    const me = document.getElementById('mem-entries') as HTMLElement;
    const du = document.getElementById('disk-usage') as HTMLElement;
    if (up) up.textContent = data.system?.uptime ?? '-';
    if (me) me.textContent = data.stats?.memoryEntries ?? '-';
    if (du) du.textContent = data.stats?.diskUsage ?? '-';

  } catch (e) {
    const status = document.getElementById('system-status') as HTMLElement;
    if (status) status.textContent = 'Данные недоступны';
  }
}
loadDashboard();
</script>
