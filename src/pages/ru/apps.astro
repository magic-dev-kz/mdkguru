  ghostkitchen: `<svg viewBox="0 0 24 24" fill="none" stroke="url(#solanaGrad)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M12 2C9 2 6 3.5 6 6c0 1.5.5 2.5 1.5 3.5"></path><path d="M12 2c3 0 6 1.5 6 4 0 1.5-.5 2.5-1.5 3.5"></path><path d="M8.5 9.5C7 11 6 12 6 14h12c0-2-1-3-2.5-4.5"></path><rect x="5" y="14" width="14" height="4" rx="1"></rect><path d="M8 18v3"></path><path d="M16 18v3"></path></svg>`,
