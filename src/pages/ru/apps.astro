---
import Layout from '../../layouts/Layout.astro';

const appIcons = {
  snobsnab: `<svg viewBox="0 0 24 24" fill="none" stroke="url(#solanaGrad)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>`,
  mdkguru: `<svg viewBox="0 0 24 24" fill="none" stroke="url(#solanaGrad)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>`,
  kazakvpn: `<svg viewBox="0 0 24 24" fill="none" stroke="url(#solanaGrad)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>`,
  qr: `<svg viewBox="0 0 24 24" fill="none" stroke="url(#solanaGrad)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line><line x1="5" y1="10" x2="19" y2="10"></line></svg>`,
};

const apps = [
  { iconKey: 'snobsnab', title: 'СнобСнаб', desc: 'Контент-сайт для строительных материалов. Статьи генерируются автоматически: Gemini исследует тему, Claude пишет текст, Imagen создаёт обложку.', status: 'live', url: 'https://www.snobsnab.ru', stack: 'Astro + Vercel + Gemini + Claude + Imagen' },
  { iconKey: 'mdkguru', title: 'MDK.GURU', desc: 'Этот сайт. Студия одного человека + ИИ. Блог, приложения, скиллы. Три языка, CMS для редактирования.', status: 'live', url: 'https://mdk.guru', stack: 'Astro + Tailwind + Decap CMS + Vercel' },
  { iconKey: 'kazakvpn', title: 'KazakVPN', desc: 'iOS VPN-клиент на WireGuard. Простой интерфейс, быстрое подключение.', status: 'development', stack: 'SwiftUI + WireGuardKit' },
  { iconKey: 'qr', title: 'QR-оплата по фото', desc: 'Фото счёта → распознавание реквизитов → QR-код для оплаты в банковском приложении. Стандарт ЦБ РФ ST00012.', status: 'development', stack: 'Python + qrcode + OCR' },
];

const statusLabels: Record<string, { text: string; color: string }> = {
  live: { text: 'Live', color: 'bg-accent-green/20 text-accent-green' },
  beta: { text: 'Beta', color: 'bg-accent-blue/20 text-accent-blue' },
  development: { text: 'В разработке', color: 'bg-accent-purple/20 text-accent-purple' },
};
---

<Layout title="Приложения" description="Проекты студии MDK.GURU - сайты, приложения, инструменты.">
  <div class="pt-24 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 py-16">
      <h1 class="text-4xl font-bold mb-2"><span class="gradient-text">Приложения</span></h1>
      <p class="text-text-muted mb-12">Проекты, которые делает один человек + ИИ-команда.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {apps.map(app => (
          <div class="card-hover p-6 rounded-xl border border-border bg-bg-card">
            <div class="flex items-start justify-between mb-3">
              <div class="w-10 h-10" set:html={appIcons[app.iconKey]} />
              <span class={`text-xs px-2 py-1 rounded-full ${statusLabels[app.status].color}`}>
                {statusLabels[app.status].text}
              </span>
            </div>
            <h3 class="text-lg font-bold text-white mb-2">{app.title}</h3>
            <p class="text-sm text-text-muted mb-3">{app.desc}</p>
            <p class="text-xs text-text-muted">{app.stack}</p>
            {app.url && (
              <a href={app.url} target="_blank" class="inline-block mt-3 text-sm text-accent-purple hover:underline">
                Открыть →
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>
