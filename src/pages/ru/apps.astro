interface AppItem {
  iconKey: string;
  title: string;
  desc: string;
  status: string;
  url?: string;
  slug?: string;
  stack: string;
}

const webApps: AppItem[] = [
  { iconKey: 'snobsnab', title: 'СнобСнаб', desc: 'Контент-сайт для строительных материалов. Статьи генерируются автоматически: Gemini исследует тему, Claude пишет текст, Imagen создаёт обложку.', status: 'live', url: 'https://www.snobsnab.ru', stack: 'Astro + Vercel + Gemini + Claude + Imagen' },
  { iconKey: 'mdkguru', title: 'MDK.GURU', desc: 'Этот сайт. Студия одного человека + ИИ. Блог, приложения, скиллы. Три языка, CMS для редактирования.', status: 'live', url: 'https://mdk.guru', stack: 'Astro + Tailwind + Decap CMS + Vercel' },
  { iconKey: 'kazakvpn', title: 'KazakVPN', desc: 'iOS VPN-клиент на WireGuard. Простой интерфейс, быстрое подключение.', status: 'development', stack: 'SwiftUI + WireGuardKit' },
  { iconKey: 'qr', title: 'QR-оплата по фото', desc: 'Фото счёта -> распознавание реквизитов -> QR-код для оплаты в банковском приложении. Стандарт ЦБ РФ ST00012.', status: 'development', stack: 'Python + qrcode + OCR' },
];

const iosApps: AppItem[] = [
  { iconKey: 'roomcalc', title: 'Калькулятор Ремонта', desc: '8 строительных калькуляторов + список покупок. Плитка, краска, обои, бетон. Бесплатно навсегда, без рекламы, офлайн.', status: 'beta', slug: 'roomcalc', stack: 'SwiftUI' },
  { iconKey: 'drift', title: 'Мягкие Привычки', desc: 'Трекер привычек без наказания. Momentum вместо серий. День отдыха — полноценная функция. Одна привычка за раз.', status: 'beta', slug: 'drift', stack: 'SwiftUI + iCloud' },
  { iconKey: 'pollenpal', title: 'PollenPal — Прогноз Аллергии', desc: 'Реальная помощь аллергикам. Персональный балл безопасности по твоим аллергенам. Пыльца + воздух. Лучший час для прогулки.', status: 'live', slug: 'pollenpal', stack: 'SwiftUI + Open-Meteo API' },
  { iconKey: 'winlog', title: 'WinBoard — Дневник Побед', desc: 'Дневник побед за 30 секунд. Голосовой ввод, инсайты, календарь побед, Face ID. По методу Бодо Шефера.', status: 'beta', slug: 'winlog', stack: 'SwiftUI + Apple Speech' },
  { iconKey: 'wificard', title: 'WiFi Карточка', desc: 'Красивые карточки с QR-кодом для WiFi. Гость сканирует — подключается. 6 шаблонов, печать, офлайн.', status: 'beta', slug: 'wificard', stack: 'SwiftUI + CoreImage' },
  { iconKey: 'huecraft', title: 'HueForge — Палитра Цветов', desc: 'Один HEX — полная дизайн-система. 40+ токенов, light + dark mode, WCAG auto-fix. CSS, Swift, Tailwind, JSON.', status: 'beta', slug: 'huecraft', stack: 'SwiftUI + OKLCH' },
  { iconKey: 'currencysnap', title: 'PriceFlip — КурсОк', desc: 'Наведи камеру на ценник — увидь цену в своей валюте. 150+ валют, офлайн, для путешественников.', status: 'beta', slug: 'currencysnap', stack: 'SwiftUI + VisionKit' },
  { iconKey: 'roast', title: 'Исправь Объявление', desc: 'AI-критик объявлений. Вставь текст — получи оценку, разбор ошибок и готовый рерайт. On-device AI.', status: 'beta', slug: 'roast-my-listing', stack: 'SwiftUI + Apple Intelligence' },
  { iconKey: 'decode', title: 'Расшифруй Босса', desc: 'Расшифровка корпоративного языка. Вставь сообщение босса — получи настоящий смысл и уровень токсичности.', status: 'beta', slug: 'decode-my-boss', stack: 'SwiftUI + Apple Intelligence' },
  { iconKey: 'labelwise', title: 'ScanLabel — Сканер Состава', desc: 'Сканер состава продуктов. 236 E-добавок расшифровано, диетические алерты, рейтинги безопасности. AI на устройстве.', status: 'beta', slug: 'labelwise', stack: 'SwiftUI + VisionKit + Foundation Models' },
  { iconKey: 'ghostkitchen', title: 'FridgeMenu — Меню из Холодильника', desc: 'AI-помощник на кухне. 40 рецептов, голосовой режим готовки, управление запасами. AI на устройстве.', status: 'beta', slug: 'ghostkitchen', stack: 'SwiftUI + Foundation Models + Speech' },
];

const statusLabels: Record<string, { text: string; color: string }> = {
  live: { text: 'Live', color: 'bg-accent-green/20 text-accent-green' },
  beta: { text: 'Coming Soon', color: 'bg-accent-blue/20 text-accent-blue' },
  development: { text: 'В разработке', color: 'bg-accent-purple/20 text-accent-purple' },
};
---

<Layout title="Приложения" description="iOS-приложения и веб-проекты студии MDK.GURU. Бесплатные утилиты без рекламы.">
  <div class="pt-24 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 py-16">
      <h1 class="text-4xl font-bold mb-2"><span class="gradient-text">Приложения</span></h1>
      <p class="text-text-muted mb-12">Проекты, которые делает один человек + ИИ-команда.</p>

      <h2 class="text-2xl font-bold text-white mb-6">iOS</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">
        {iosApps.map(app => (
          <a href={`/ru/apps/${app.slug}`} class="card-hover p-6 rounded-xl border border-border bg-bg-card block transition-transform hover:scale-[1.02]">
            <div class="flex items-start justify-between mb-3">
              <div class="w-10 h-10" set:html={appIcons[app.iconKey]} />
              <span class={`text-xs px-2 py-1 rounded-full ${statusLabels[app.status].color}`}>
                {statusLabels[app.status].text}
              </span>
            </div>
            <h3 class="text-lg font-bold text-white mb-2">{app.title}</h3>
            <p class="text-sm text-text-muted mb-3">{app.desc}</p>
            <p class="text-xs text-text-muted">{app.stack}</p>
          </a>
        ))}
      </div>

      <h2 class="text-2xl font-bold text-white mb-6">Веб-проекты</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {webApps.map(app => (
          <div class="card-hover p-6 rounded-xl border border-border bg-bg-card">
            <div class="flex items-start justify-between mb-3">
              <div class="w-10 h-10" set:html={appIcons[app.iconKey]} />
              <span class={`text-xs px-2 py-1 rounded-full ${statusLabels[app.status].color}`}>
                {statusLabels[app.status].text}
              </span>
            </div>
            <h3 class="text-lg font-bold text-white mb-2">{app.title}</h3>
            <p class="text-sm text-text-muted mb-3">{app.desc}</p>
            <p class="text-xs text-text-muted">{app.stack}</p>
            {app.url && (
              <a href={app.url} target="_blank" class="inline-block mt-3 text-sm text-accent-purple hover:underline">
                Открыть &rarr;
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>
