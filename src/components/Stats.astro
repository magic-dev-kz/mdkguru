---
import { getLangFromUrl } from '../i18n/translations';
const lang = getLangFromUrl(Astro.url);

const stats = [
  { value: '5', label: lang === 'ru' ? 'ИИ-агентов' : lang === 'es' ? 'agentes IA' : 'AI agents' },
  { value: '3', label: lang === 'ru' ? 'бизнеса' : lang === 'es' ? 'negocios' : 'businesses' },
  { value: '24/7', label: lang === 'ru' ? 'без выходных' : lang === 'es' ? 'sin descanso' : 'non-stop' },
  { value: '26', label: lang === 'ru' ? 'кронов' : 'cron jobs' },
];
---

<section class="py-16 px-4 border-y border-border">
  <div class="max-w-4xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8">
    {stats.map(stat => (
      <div class="text-center">
        <div class="text-3xl sm:text-4xl font-bold gradient-text mb-1">{stat.value}</div>
        <div class="text-sm text-text-muted">{stat.label}</div>
      </div>
    ))}
  </div>
</section>
