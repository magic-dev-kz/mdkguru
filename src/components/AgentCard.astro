---
interface Props { emoji: string; name: string; role: string; description: string; icon?: string; }
const { emoji, name, role, description, icon } = Astro.props;
---

<div class="card-hover p-6 rounded-xl border border-border bg-bg-card">
  {icon ? (
    <div class="w-10 h-10 mb-3" set:html={icon} />
  ) : (
    <div class="text-3xl mb-3">{emoji}</div>
  )}
  <h3 class="text-lg font-bold text-white mb-1">{name}</h3>
  <p class="text-sm text-accent-purple mb-2">{role}</p>
  <p class="text-sm text-text-muted">{description}</p>
</div>
