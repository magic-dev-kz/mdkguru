---
import AgentCard from './AgentCard.astro';
import { getLangFromUrl, useTranslations } from '../i18n/translations';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const icons = {
  mo: `<svg viewBox="0 0 24 24" fill="none" stroke="url(#solanaGrad)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect><rect x="9" y="9" width="6" height="6"></rect><line x1="9" y1="1" x2="9" y2="4"></line><line x1="15" y1="1" x2="15" y2="4"></line><line x1="9" y1="20" x2="9" y2="23"></line><line x1="15" y1="20" x2="15" y2="23"></line><line x1="20" y1="9" x2="23" y2="9"></line><line x1="20" y1="14" x2="23" y2="14"></line><line x1="1" y1="9" x2="4" y2="9"></line><line x1="1" y1="14" x2="4" y2="14"></line></svg>`,
  izya: `<svg viewBox="0 0 24 24" fill="none" stroke="url(#solanaGrad)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path></svg>`,
  molot: `<svg viewBox="0 0 24 24" fill="none" stroke="url(#solanaGrad)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><circle cx="12" cy="12" r="10"></circle><line x1="22" y1="12" x2="18" y2="12"></line><line x1="6" y1="12" x2="2" y2="12"></line><line x1="12" y1="6" x2="12" y2="2"></line><line x1="12" y1="22" x2="12" y2="18"></line><circle cx="12" cy="12" r="4"></circle></svg>`,
  leo: `<svg viewBox="0 0 24 24" fill="none" stroke="url(#solanaGrad)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M12 19l7-7 3 3-7 7-3-3z"></path><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"></path><path d="M2 2l7.586 7.586"></path><circle cx="11" cy="11" r="2"></circle></svg>`,
  house: `<svg viewBox="0 0 24 24" fill="none" stroke="url(#solanaGrad)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>`,
  soon: `<svg viewBox="0 0 24 24" fill="none" stroke="url(#solanaGrad)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="12" y1="8" x2="12" y2="16"></line><line x1="8" y1="12" x2="16" y2="12"></line></svg>`,
};
---

<section class="py-24 px-4">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4">
      <span class="gradient-text">{t('features.title')}</span>
    </h2>
    <p class="text-center text-text-muted mb-12">24/7. {lang === 'ru' ? 'Без выходных. Без зарплаты.' : lang === 'es' ? 'Sin descanso. Sin salario.' : 'No days off. No salary.'}</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <AgentCard emoji="⚙️" icon={icons.mo} name={lang === 'ru' ? 'Мо' : 'Mo'} role="COO" description={t('features.mo')} />
      <AgentCard emoji="🎬" icon={icons.izya} name={lang === 'ru' ? 'Изя' : 'Izya'} role="SMM" description={t('features.izya')} />
      <AgentCard emoji="🔨" icon={icons.molot} name={lang === 'ru' ? 'Молот' : 'Molot'} role="Scout" description={t('features.molot')} />
      <AgentCard emoji="📐" icon={icons.leo} name={lang === 'ru' ? 'Лео' : 'Leo'} role="Design" description={t('features.leo')} />
      <AgentCard emoji="🩺" icon={icons.house} name={lang === 'ru' ? 'Хаус' : 'House'} role="SRE" description={t('features.house')} />
      <div class="card-hover p-6 rounded-xl border border-dashed border-border flex flex-col items-center justify-center gap-3">
        <div class="w-10 h-10" set:html={icons.soon} />
        <p class="text-sm text-text-muted">+ {lang === 'ru' ? 'Скоро новые' : 'Coming soon'}</p>
      </div>
    </div>
  </div>
</section>
