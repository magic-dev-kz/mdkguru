---
import AgentCard from './AgentCard.astro';
import { getLangFromUrl, useTranslations } from '../i18n/translations';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const agents_data = {
  mo:    { icon: `<img src="/agents/avatar_mo.png" alt="Мо" class="w-full h-full rounded-full object-cover" loading="lazy" />`, color: 'rgba(60, 100, 220, 0.15)' },
  izya:  { icon: `<img src="/agents/avatar_izya.png" alt="Изя" class="w-full h-full rounded-full object-cover" loading="lazy" />`, color: 'rgba(220, 50, 180, 0.15)' },
  molot: { icon: `<img src="/agents/avatar_molot.png" alt="Молот" class="w-full h-full rounded-full object-cover" loading="lazy" />`, color: 'rgba(180, 40, 40, 0.15)' },
  leo:   { icon: `<img src="/agents/avatar_leo.png" alt="Лео" class="w-full h-full rounded-full object-cover" loading="lazy" />`, color: 'rgba(255, 215, 0, 0.15)' },
  house: { icon: `<img src="/agents/avatar_house.png" alt="Хаус" class="w-full h-full rounded-full object-cover" loading="lazy" />`, color: 'rgba(40, 180, 80, 0.15)' },
  steve: { icon: `<img src="/agents/avatar_steve.png" alt="Стив" class="w-full h-full rounded-full object-cover" loading="lazy" />`, color: 'rgba(230, 140, 30, 0.15)' },
  max:   { icon: `<img src="/agents/avatar_max.png" alt="Макс" class="w-full h-full rounded-full object-cover" loading="lazy" />`, color: 'rgba(0, 220, 50, 0.15)' },
};
---

<section class="py-24 px-4">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4">
      <span class="gradient-text">{t('features.title')}</span>
    </h2>
    <p class="text-center text-text-muted mb-12">24/7. {lang === 'ru' ? 'Без выходных. Без зарплаты.' : lang === 'es' ? 'Sin descanso. Sin salario.' : 'No days off. No salary.'}</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <AgentCard emoji="⚙️" icon={agents_data.mo.icon} accentColor={agents_data.mo.color} name={lang === 'ru' ? 'Мо' : 'Mo'} role="COO" description={t('features.mo')} />
      <AgentCard emoji="📣" icon={agents_data.izya.icon} accentColor={agents_data.izya.color} name={lang === 'ru' ? 'Изя' : 'Izya'} role="SMM" description={t('features.izya')} />
      <AgentCard emoji="🔨" icon={agents_data.molot.icon} accentColor={agents_data.molot.color} name={lang === 'ru' ? 'Молот' : 'Molot'} role="Scout" description={t('features.molot')} />
      <AgentCard emoji="📐" icon={agents_data.leo.icon} accentColor={agents_data.leo.color} name={lang === 'ru' ? 'Лео' : 'Leo'} role="Design" description={t('features.leo')} />
      <AgentCard emoji="🩺" icon={agents_data.house.icon} accentColor={agents_data.house.color} name={lang === 'ru' ? 'Хаус' : 'House'} role="SRE" description={t('features.house')} />
      <AgentCard emoji="🧭" icon={agents_data.steve.icon} accentColor={agents_data.steve.color} name={lang === 'ru' ? 'Стив' : 'Steve'} role="Product" description={t('features.steve')} />
      <AgentCard emoji="⚡" icon={agents_data.max.icon} accentColor={agents_data.max.color} name={lang === 'ru' ? 'Макс' : 'Max'} role="Infra" description={t('features.max')} />
    </div>
  </div>
</section>
