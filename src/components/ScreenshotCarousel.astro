---
interface Screenshot {
  src: string;
  alt: string;
}
interface Props {
  screenshots: Screenshot[];
  id?: string;
}
const { screenshots, id = 'carousel' } = Astro.props;
---

<div class="mb-12 relative group" data-carousel={id}>
  <!-- Carousel container -->
  <div class="overflow-hidden rounded-2xl">
    <div class="flex transition-transform duration-300 ease-out" data-carousel-track>
      {screenshots.map((s, i) => (
        <div class="w-full flex-shrink-0 flex justify-center px-4" data-carousel-slide>
          <img
            src={s.src}
            alt={s.alt}
            class="h-[420px] sm:h-[520px] rounded-2xl shadow-lg select-none"
            loading={i === 0 ? 'eager' : 'lazy'}
            draggable="false"
          />
        </div>
      ))}
    </div>
  </div>

  <!-- Arrow buttons -->
  <button
    data-carousel-prev
    class="absolute left-2 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-black/60 backdrop-blur-sm border border-white/10 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200 hover:bg-black/80 disabled:opacity-0 z-10"
    aria-label="Previous"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
  </button>
  <button
    data-carousel-next
    class="absolute right-2 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-black/60 backdrop-blur-sm border border-white/10 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200 hover:bg-black/80 disabled:opacity-0 z-10"
    aria-label="Next"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
  </button>

  <!-- Dots -->
  <div class="flex justify-center gap-2 mt-4" data-carousel-dots>
    {screenshots.map((_, i) => (
      <button
        class={`w-2 h-2 rounded-full transition-all duration-200 ${i === 0 ? 'bg-white w-6' : 'bg-white/30 hover:bg-white/50'}`}
        data-carousel-dot={i}
        aria-label={`Slide ${i + 1}`}
      />
    ))}
  </div>
</div>

<script>
  document.querySelectorAll('[data-carousel]').forEach(carousel => {
    const track = carousel.querySelector('[data-carousel-track]') as HTMLElement;
    const slides = carousel.querySelectorAll('[data-carousel-slide]');
    const prevBtn = carousel.querySelector('[data-carousel-prev]') as HTMLButtonElement;
    const nextBtn = carousel.querySelector('[data-carousel-next]') as HTMLButtonElement;
    const dots = carousel.querySelectorAll('[data-carousel-dot]');
    let current = 0;
    const total = slides.length;

    // Touch/drag state
    let startX = 0;
    let isDragging = false;
    let dragOffset = 0;

    function goTo(index: number) {
      current = Math.max(0, Math.min(index, total - 1));
      track.style.transform = `translateX(-${current * 100}%)`;
      prevBtn.disabled = current === 0;
      nextBtn.disabled = current === total - 1;
      // On mobile, always show arrows slightly
      dots.forEach((dot, i) => {
        const el = dot as HTMLElement;
        if (i === current) {
          el.classList.add('bg-white', 'w-6');
          el.classList.remove('bg-white/30');
        } else {
          el.classList.remove('bg-white', 'w-6');
          el.classList.add('bg-white/30');
        }
      });
    }

    prevBtn.addEventListener('click', () => goTo(current - 1));
    nextBtn.addEventListener('click', () => goTo(current + 1));
    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        goTo(Number((dot as HTMLElement).dataset.carouselDot));
      });
    });

    // Touch support
    track.addEventListener('touchstart', (e: TouchEvent) => {
      startX = e.touches[0].clientX;
      isDragging = true;
      track.style.transition = 'none';
    }, { passive: true });

    track.addEventListener('touchmove', (e: TouchEvent) => {
      if (!isDragging) return;
      dragOffset = e.touches[0].clientX - startX;
      const pct = (dragOffset / (carousel as HTMLElement).offsetWidth) * 100;
      track.style.transform = `translateX(calc(-${current * 100}% + ${pct}%))`;
    }, { passive: true });

    track.addEventListener('touchend', () => {
      isDragging = false;
      track.style.transition = 'transform 300ms ease-out';
      if (Math.abs(dragOffset) > 50) {
        goTo(dragOffset > 0 ? current - 1 : current + 1);
      } else {
        goTo(current);
      }
      dragOffset = 0;
    });

    // Mouse drag support (desktop)
    track.addEventListener('mousedown', (e: MouseEvent) => {
      startX = e.clientX;
      isDragging = true;
      track.style.transition = 'none';
      track.style.cursor = 'grabbing';
      e.preventDefault();
    });

    window.addEventListener('mousemove', (e: MouseEvent) => {
      if (!isDragging) return;
      dragOffset = e.clientX - startX;
      const pct = (dragOffset / (carousel as HTMLElement).offsetWidth) * 100;
      track.style.transform = `translateX(calc(-${current * 100}% + ${pct}%))`;
    });

    window.addEventListener('mouseup', () => {
      if (!isDragging) return;
      isDragging = false;
      track.style.transition = 'transform 300ms ease-out';
      track.style.cursor = '';
      if (Math.abs(dragOffset) > 50) {
        goTo(dragOffset > 0 ? current - 1 : current + 1);
      } else {
        goTo(current);
      }
      dragOffset = 0;
    });

    // Keyboard
    carousel.addEventListener('keydown', (e: Event) => {
      const key = (e as KeyboardEvent).key;
      if (key === 'ArrowLeft') goTo(current - 1);
      if (key === 'ArrowRight') goTo(current + 1);
    });

    goTo(0);
  });
</script>
