---
import { getLangFromUrl } from '../i18n/translations';
const lang = getLangFromUrl(Astro.url);

const texts = {
  ru: {
    title: 'Не пропусти новые кейсы',
    desc: 'Подписывайся на рассылку - новые статьи, практика, инструменты. Без спама.',
    placeholder: 'Email',
    btn: 'Подписаться',
    success: 'Готово! Проверь почту 🎉',
    error: 'Что-то пошло не так. Попробуй ещё раз.',
    tg: 'или подписывайся в Telegram →',
  },
  en: {
    title: "Don't miss new cases",
    desc: 'Subscribe - new articles, practice, tools. No spam.',
    placeholder: 'Email',
    btn: 'Subscribe',
    success: 'Done! Check your inbox 🎉',
    error: 'Something went wrong. Try again.',
    tg: 'or subscribe on Telegram →',
  },
  es: {
    title: 'No te pierdas nuevos casos',
    desc: 'Suscríbete - nuevos artículos, práctica, herramientas. Sin spam.',
    placeholder: 'Email',
    btn: 'Suscribirse',
    success: '¡Listo! Revisa tu correo 🎉',
    error: 'Algo salió mal. Intenta de nuevo.',
    tg: 'o suscríbete en Telegram →',
  },
};
const t = texts[lang] || texts.ru;
---

<section class="py-20 px-4">
  <div class="max-w-2xl mx-auto text-center">
    <div class="p-8 rounded-2xl border border-accent-purple/20 bg-gradient-to-br from-accent-purple/5 to-accent-green/5">
      <h2 class="text-2xl font-bold text-white mb-3">{t.title}</h2>
      <p class="text-text-muted mb-6">{t.desc}</p>

      <form id="subscribe-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto mb-4">
        <input
          type="email"
          id="email-input"
          placeholder={t.placeholder}
          required
          class="flex-1 px-4 py-3 rounded-lg bg-bg-primary border border-border text-white placeholder-text-muted focus:outline-none focus:border-accent-purple transition-colors"
        />
        <button
          type="submit"
          id="submit-btn"
          class="px-6 py-3 rounded-lg bg-gradient-to-r from-accent-purple to-accent-green text-white font-semibold hover:opacity-90 transition-opacity whitespace-nowrap"
        >
          {t.btn}
        </button>
      </form>

      <div id="form-message" class="text-sm hidden mb-4"></div>

      <a href="https://t.me/mdkguru" target="_blank" class="text-sm text-text-muted hover:text-accent-purple transition-colors">
        {t.tg}
      </a>
    </div>
  </div>
</section>

<script define:vars={{ success: t.success, error: t.error }}>
  document.getElementById('subscribe-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const input = document.getElementById('email-input');
    const btn = document.getElementById('submit-btn');
    const msg = document.getElementById('form-message');
    const email = input?.value;

    if (!email) return;

    btn.disabled = true;
    btn.textContent = '...';

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      if (res.ok) {
        msg.textContent = success;
        msg.className = 'text-sm text-accent-green mb-4';
        input.value = '';
      } else {
        msg.textContent = error;
        msg.className = 'text-sm text-red-400 mb-4';
      }
    } catch {
      msg.textContent = error;
      msg.className = 'text-sm text-red-400 mb-4';
    }

    btn.disabled = false;
    btn.textContent = e.target.querySelector('button').dataset.label || 'OK';
  });
</script>
