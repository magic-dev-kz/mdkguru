---
import { getLangFromUrl } from '../i18n/translations';
const lang = getLangFromUrl(Astro.url);

const texts = {
  ru: { title: 'Не пропусти новые кейсы', desc: 'Подписывайся на канал - практика, грабли, инструменты. Без воды.', btn: 'Подписаться на @mdkguru' },
  en: { title: "Don't miss new cases", desc: 'Subscribe to the channel - practice, mistakes, tools. No fluff.', btn: 'Subscribe to @mdkguru' },
  es: { title: 'No te pierdas nuevos casos', desc: 'Suscríbete al canal - práctica, errores, herramientas. Sin relleno.', btn: 'Suscribirse a @mdkguru' },
};
const t = texts[lang] || texts.ru;
---

<section class="py-20 px-4">
  <div class="max-w-2xl mx-auto text-center">
    <div class="p-8 rounded-2xl border border-accent-purple/20 bg-gradient-to-br from-accent-purple/5 to-accent-green/5">
      <h2 class="text-2xl font-bold text-white mb-3">{t.title}</h2>
      <p class="text-text-muted mb-6">{t.desc}</p>
      <a
        href="https://t.me/mdkguru"
        target="_blank"
        class="inline-flex items-center gap-3 px-8 py-3 rounded-lg bg-gradient-to-r from-accent-purple to-accent-green text-white font-semibold hover:opacity-90 transition-opacity"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
        </svg>
        {t.btn}
      </a>
    </div>
  </div>
</section>
