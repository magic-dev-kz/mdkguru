---
import { getLangFromUrl, useTranslations } from '../i18n/translations';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="border-t border-border bg-bg-primary">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <img src="/logo.svg" alt="MDK.GURU" class="h-7 w-auto" />
        <p class="mt-2 text-sm text-text-muted">{t('hero.title')}<br/>{t('hero.subtitle')}</p>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-white mb-3">Links</h4>
        <div class="space-y-2">
          <a href={`/${lang}/blog`} class="block text-sm text-text-muted hover:text-white transition-colors">{t('nav.blog')}</a>
          <a href={`/${lang}/apps`} class="block text-sm text-text-muted hover:text-white transition-colors">{t('nav.apps')}</a>
          <a href={`/${lang}/skills`} class="block text-sm text-text-muted hover:text-white transition-colors">{t('nav.skills')}</a>
        </div>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-white mb-3">Telegram</h4>
        <a href="https://t.me/mdkguru" target="_blank" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-accent-purple/10 border border-accent-purple/30 text-accent-purple hover:bg-accent-purple/20 transition-colors text-sm">
          {t('footer.telegram')}
        </a>
      </div>
    </div>
    <div class="mt-8 pt-8 border-t border-border text-center">
      <p class="text-xs text-text-muted">{t('footer.copyright')}</p>
    </div>
  </div>
</footer>
