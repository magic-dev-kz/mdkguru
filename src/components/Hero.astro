---
import { getLangFromUrl, useTranslations } from '../i18n/translations';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Animated mesh gradient background (Solana-style) -->
  <div class="absolute inset-0 hero-gradient"></div>

  <!-- Vertical gradient stripes - animated -->
  <div class="absolute inset-0 stripe-container">
    <div class="stripe stripe-1"></div>
    <div class="stripe stripe-2"></div>
    <div class="stripe stripe-3"></div>
    <div class="stripe stripe-4"></div>
    <div class="stripe stripe-5"></div>
    <div class="stripe stripe-6"></div>
  </div>

  <!-- Radial light burst -->
  <div class="absolute inset-0 bg-radial-light"></div>

  <!-- Noise texture overlay -->
  <div class="absolute inset-0 noise-overlay"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto px-4 text-center pt-20">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-accent-purple/30 bg-accent-purple/10 mb-8 backdrop-blur-sm">
      <div class="w-2 h-2 rounded-full bg-accent-green animate-pulse"></div>
      <span class="text-xs text-text-secondary">5 agents online</span>
    </div>

    <h1 class="text-5xl sm:text-6xl md:text-7xl font-bold leading-tight mb-4">
      <span class="gradient-text">{t('hero.title')}</span>
    </h1>
    <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white/90 mb-6">{t('hero.subtitle')}</h2>
    <p class="text-lg sm:text-xl text-text-secondary max-w-2xl mx-auto mb-10 leading-relaxed">{t('hero.description')}</p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href={`/${lang}/blog`} class="px-8 py-3 rounded-lg bg-gradient-to-r from-accent-purple to-accent-green text-white font-semibold hover:opacity-90 transition-opacity hover:shadow-lg hover:shadow-accent-purple/25">
        {t('hero.cta')}
      </a>
      <a href="https://t.me/mdkguru" target="_blank" class="px-8 py-3 rounded-lg border border-border text-text-secondary hover:text-white hover:border-white/30 transition-all backdrop-blur-sm">
        {t('hero.cta2')} →
      </a>
    </div>
  </div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-bg-primary to-transparent"></div>
</section>

<style>
  .hero-gradient {
    background: #0e0e10;
  }

  /* Floating blob animations - Solana style organic movement */
  /* Vertical gradient stripes */
  .stripe-container {
    overflow: hidden;
  }

  .stripe {
    position: absolute;
    top: -20%;
    bottom: -20%;
    width: 200px;
    filter: blur(80px);
  }

  .stripe-1 {
    left: 5%;
    background: linear-gradient(180deg, transparent, #9945FF, transparent);
    opacity: 0.35;
    animation: stripe-shift-1 8s ease-in-out infinite;
  }
  .stripe-2 {
    left: 25%;
    background: linear-gradient(180deg, transparent, #14F195, transparent);
    opacity: 0.25;
    animation: stripe-shift-2 10s ease-in-out infinite;
  }
  .stripe-3 {
    left: 45%;
    background: linear-gradient(180deg, transparent, #7B3FE4, #00D1FF, transparent);
    opacity: 0.3;
    animation: stripe-shift-3 7s ease-in-out infinite;
  }
  .stripe-4 {
    left: 60%;
    background: linear-gradient(180deg, transparent, #14F195, transparent);
    opacity: 0.2;
    animation: stripe-shift-4 12s ease-in-out infinite;
  }
  .stripe-5 {
    left: 75%;
    background: linear-gradient(180deg, transparent, #9945FF, #14F195, transparent);
    opacity: 0.3;
    animation: stripe-shift-5 9s ease-in-out infinite;
  }
  .stripe-6 {
    left: 90%;
    background: linear-gradient(180deg, transparent, #00D1FF, transparent);
    opacity: 0.2;
    animation: stripe-shift-6 11s ease-in-out infinite;
  }

  @keyframes stripe-shift-1 {
    0%, 100% { transform: translateY(0) scaleY(1); opacity: 0.35; }
    50% { transform: translateY(-60px) scaleY(1.1); opacity: 0.5; }
  }
  @keyframes stripe-shift-2 {
    0%, 100% { transform: translateY(0) scaleY(1); opacity: 0.25; }
    50% { transform: translateY(80px) scaleY(1.15); opacity: 0.4; }
  }
  @keyframes stripe-shift-3 {
    0%, 100% { transform: translateY(0) scaleY(1); opacity: 0.3; }
    50% { transform: translateY(-40px) scaleY(1.2); opacity: 0.45; }
  }
  @keyframes stripe-shift-4 {
    0%, 100% { transform: translateY(0) scaleY(1); opacity: 0.2; }
    50% { transform: translateY(50px) scaleY(1.1); opacity: 0.35; }
  }
  @keyframes stripe-shift-5 {
    0%, 100% { transform: translateY(0) scaleY(1); opacity: 0.3; }
    50% { transform: translateY(-70px) scaleY(1.15); opacity: 0.45; }
  }
  @keyframes stripe-shift-6 {
    0%, 100% { transform: translateY(0) scaleY(1); opacity: 0.2; }
    50% { transform: translateY(40px) scaleY(1.1); opacity: 0.3; }
  }

  /* Radial light from center */
  .bg-radial-light {
    background: radial-gradient(ellipse 60% 50% at 50% 40%, rgba(153, 69, 255, 0.12) 0%, rgba(20, 241, 149, 0.05) 40%, transparent 70%);
  }

  /* Noise texture for depth */
  .noise-overlay {
    opacity: 0.02;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
    background-size: 256px 256px;
  }
</style>
